# ============================================================
# EJEMPLO de configuración de SonarQube / SonarCloud
# ============================================================
# Pasos:
#   1. Crea tu cuenta en https://sonarcloud.io (con tu cuenta de GitHub)
#   2. Importa el repositorio y copia el "Project Key" y la "Organization"
#   3. Genera un token en: My Account -> Security -> Generate Token
#   4. En GitHub: Settings -> Secrets and variables -> Actions
#      crea el secret SONAR_TOKEN con ese token
#   5. Reemplaza TU_PROJECT_KEY y TU_ORGANIZACION en
#      .github/workflows/ci.yml con tus valores
#
# NOTA: al ser un proyecto Maven, el análisis se ejecuta con
# "mvn sonar:sonar" (ya configurado en el workflow) y estas
# propiedades se pasan como -Dsonar.xxx. Este archivo solo
# documenta los valores que debes reemplazar.
# ============================================================

# Identificador del proyecto en SonarCloud (lo da la plataforma al importar el repo)
sonar.projectKey=TU_PROJECT_KEY

# Tu organización en SonarCloud (normalmente tu usuario de GitHub)
sonar.organization=TU_ORGANIZACION

# URL del servidor: SonarCloud (nube) o tu instancia propia de SonarQube
sonar.host.url=https://sonarcloud.io

# El token NUNCA se escribe en un archivo del repositorio.
# Va como secret SONAR_TOKEN en GitHub Actions.
# sonar.token=<va en el secret SONAR_TOKEN>
